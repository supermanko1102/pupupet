{
  "expo": {
    "name": "口袋便便",
    "slug": "pupupet",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pupupet",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "bundleIdentifier": "com.alex.pupupet",
      "usesAppleSignIn": true,
      "supportsTablet": true,
      "infoPlist": {
        "CFBundleDisplayName": "口袋便便",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E9FBF8",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png",
          "color": "#20B2AA",
          "sounds": []
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "讓 PupuPet 存取相簿以補登寵物便便照片。",
          "microphonePermission": false,
          "cameraPermission": "讓 PupuPet 使用相機拍攝寵物便便照片。"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#D8F3EB",
          "dark": {
            "backgroundColor": "#D8F3EB"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "2deacd26-c89b-4e29-9347-a87b0c1caa6b"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/2deacd26-c89b-4e29-9347-a87b0c1caa6b"
    }
  }
}
